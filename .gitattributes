# Handle line endings automatically
* text=auto

# Force LF for source files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.mjs  text eol=lf
*.env  text eol=lf

# Keep binary files binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.pdf  binary
*.ico  binary
