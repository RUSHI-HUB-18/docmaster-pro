# Root-level .gitignore for DocMaster Pro

# ── Node ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Next.js ────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# ── Uploads / processed files (runtime, NOT in repo) ──
uploads/
*.pdf
*.docx
*.pptx
*.xlsx
*.jpg
*.jpeg
*.png
*.webp

# ── Environment variables ──────────────────────────────
.env
.env.local
.env.production
.env*.local

# ── OS ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user

# ── Misc ─────────────────────────────────────────────
.vercel
*.pem
